# MCP Environment Variables Configuration Template
# Copy this file to .env and fill in your actual API keys and credentials

# =============================================================================
# EXISTING PROJECT VARIABLES (already configured)
# =============================================================================
TELEGRAM_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_ASSISTANT_ID=asst-your_assistant_id

# Google Sheets (already configured)
SHEET_URL=your_auth_sheet_url
TICKETS_SHEET_URL=your_tickets_sheet_url
PROMOTIONS_SHEET_URL=your_promotions_sheet_url

# =============================================================================
# DATABASE CONNECTIONS
# =============================================================================
# PostgreSQL
POSTGRES_CONNECTION_STRING=postgresql://username:password@localhost:5432/marketing_bot

# MySQL
MYSQL_CONNECTION_STRING=mysql://username:password@localhost:3306/marketing_bot

# =============================================================================
# SEARCH AND WEB SERVICES
# =============================================================================
# Brave Search API
BRAVE_API_KEY=your_brave_search_api_key

# News API
NEWS_API_KEY=your_news_api_key

# OpenWeather API
OPENWEATHER_API_KEY=your_openweather_api_key

# YouTube API
YOUTUBE_API_KEY=your_youtube_api_key

# =============================================================================
# SOCIAL MEDIA APIS
# =============================================================================
# Reddit API
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Twitter/X API
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# LinkedIn API
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# =============================================================================
# GOOGLE SERVICES
# =============================================================================
# Google Cloud Platform
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/google-credentials.json

# Google Drive
GOOGLE_DRIVE_CREDENTIALS=/path/to/your/google-drive-credentials.json

# Google Sheets (enhanced)
GOOGLE_SHEETS_CREDENTIALS=/path/to/your/google-sheets-credentials.json

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS=/path/to/your/google-calendar-credentials.json

# Gmail
GMAIL_CREDENTIALS=/path/to/your/gmail-credentials.json

# =============================================================================
# CLOUD PLATFORMS
# =============================================================================
# AWS
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# Kubernetes
KUBECONFIG=/path/to/your/kubeconfig

# =============================================================================
# COMMUNICATION PLATFORMS
# =============================================================================
# Slack
SLACK_BOT_TOKEN=xoxb-your_slack_bot_token
SLACK_APP_TOKEN=xapp-your_slack_app_token

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token

# =============================================================================
# AI SERVICES
# =============================================================================
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# =============================================================================
# PROJECT MANAGEMENT
# =============================================================================
# GitHub
GITHUB_TOKEN=ghp_your_github_personal_access_token

# Jira
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your_email@domain.com
JIRA_API_TOKEN=your_jira_api_token

# Confluence
CONFLUENCE_URL=https://your-domain.atlassian.net
CONFLUENCE_USERNAME=your_email@domain.com
CONFLUENCE_API_TOKEN=your_confluence_api_token

# Notion
NOTION_API_KEY=secret_your_notion_api_key

# Airtable
AIRTABLE_API_KEY=key_your_airtable_api_key
AIRTABLE_BASE_ID=app_your_airtable_base_id

# =============================================================================
# AUTOMATION SERVICES
# =============================================================================
# Zapier
ZAPIER_API_KEY=your_zapier_api_key

# IFTTT
IFTTT_WEBHOOK_KEY=your_ifttt_webhook_key

# =============================================================================
# SECURITY AND MONITORING
# =============================================================================
# Add any additional security tokens or monitoring API keys here
SECURITY_SCAN_API_KEY=your_security_scan_api_key
MONITORING_API_KEY=your_monitoring_api_key

# =============================================================================
# DEVELOPMENT AND TESTING
# =============================================================================
# Environment
NODE_ENV=development
DEBUG=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=/Users/verakoroleva/Desktop/@marketing/mcp.log

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit this file with real API keys to version control
# 2. Use environment-specific .env files (.env.development, .env.production)
# 3. Rotate API keys regularly for security
# 4. Use least-privilege access for all API keys
# 5. Monitor API usage and set up billing alerts
# 6. Keep backup copies of important credentials in secure locations
